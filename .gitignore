# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.ropeproject

# Virtual environments
.venv

# Image/binary assets are kept on disk but not committed (HF Spaces rejects
# raw binaries; they must go through LFS/Xet). Demo example won't render on the
# Space as a result. See CLAUDE.md "Deployment".
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.mp3
*.mp4

# Example data lives in assets/ for local use only (not deployed to the Space).
assets/*.json
